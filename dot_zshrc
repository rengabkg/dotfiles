#!/usr/bin/env zsh

# Enable Powerlevel10k instant prompt. Should stay close to the top of ~/.zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
CACHE_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/"
INSTANT_PROMPT_CACHE_FILE="p10k-instant-prompt-${(%):-%n}.zsh"
if [[ -r "${CACHE_DIR}${INSTANT_PROMPT_CACHE_FILE}" ]]; then
  source "${CACHE_DIR}${INSTANT_PROMPT_CACHE_FILE}"
fi

export ZSH=$HOME/.oh-my-zsh
ZSH_THEME="powerlevel10k/powerlevel10k"
DISABLE_AUTO_UPDATE="true"
ZSH_DISABLE_COMPFIX="true"
plugins=(
    direnv
    gitfast
    colored-man-pages
    zsh-autosuggestions
    zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh
[[ ! -f ~/.fzf.zsh ]] || source ~/.fzf.zsh

export CLOUDSDK_PYTHON=/opt/homebrew/bin/python3

# Lazy-load gcloud completions only when first needed.
function gcloud() {
  unfunction gcloud
  source "$(brew --prefix)/share/google-cloud-sdk/completion.zsh.inc" 2>/dev/null
  gcloud "$@"
}

alias ssh="kitty +kitten ssh"
